# 复制为 .env 后填写（勿提交 .env）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
# 多模态：顾问与标签守护可共用；标签守护未单独配置时亦用此值（代码内默认 qwen3.6-plus 见 mammo_label_heuristic）
QWEN_VL_MODEL=qwen3.6-plus
# 可选：仅「标签守护」VL（ask_vl_label_*），不覆盖顾问看图模型
# QWEN_VL_LABEL_MODEL=
# 可选：ask_vl_label_bbox HTTP 超时（秒）；run_mammo_sd15 生成脚本若存在亦可能单独设 POST 超时
# LABEL_VL_BBOX_TIMEOUT_SEC=60
# 可选：片缘涂黑参数（仅 blackout 形参为默认/None 时生效；见 mammo_label_heuristic 模块注释）
# LABEL_GUARD_DEBUG=1
# LABEL_BLACKOUT_PAD=4
# LABEL_BLACKOUT_MARGIN_FRAC=0.22
# LABEL_MAX_BOX_AREA_FRAC=0.052
# LABEL_MAX_BOX_SIDE_FRAC=0.36

# 全流程报告脚本的可选文本后端（配置了则优先 DeepSeek；详见 scripts/assistant/ask_advisor.py）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-pro
# ADVISOR_TEXT_BACKEND=auto

# GLM（智谱）文本后端；ADVISOR_TEXT_BACKEND=auto 时的优先级：DeepSeek > GLM > Qwen
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-5.1

# 其他工具链变量（按需）
REDIS_URL=redis://localhost:6379/0
